{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "^test"
            ]
        },
        "test:int": {
            "dependsOn": [
                "^test:int"
            ]
        },
        "test:e2e": {
            "dependsOn": [
                "^test:e2e"
            ]
        },
        "db:generate": {
            "cache": false
        },
        "db:migrate:dev": {
            "cache": false
        },
        "db:migrate:deploy": {
            "cache": false
        },
        "db:seed": {
            "cache": false
        },
        "db:reset": {
            "cache": false
        }
    }
}